@page "/"
@inject HttpClient Http
@inject NavigationManager Nav

<MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Effere Vexillum</MudText>
<MudText Typo="Typo.subtitle1" Align="Align.Center" GutterBottom="true">The Flag Guessing Game</MudText>

<MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">
    @if (isLoaded)
    {
        if (isLoggedIn)
        {
            <text>Hello @username!</text>
        }
        else
        {
            <text>Hello guest!</text>
        }
    }
</MudText>

<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h5" GutterBottom="true">Create Lobby</MudText>
                <MudText>Start a new game for you and your friends.</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo("/create-lobby"))">Create</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h5" GutterBottom="true">Join Lobby</MudText>
                <MudTextField @bind-Value="JoinCode" Label="Lobby Code" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="JoinLobby" Disabled="@string.IsNullOrWhiteSpace(JoinCode)">Join</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string JoinCode { get; set; } = "";
    private string username = string.Empty;
    private bool isLoggedIn = false;
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/api/auth/manage/info");
            if (response.IsSuccessStatusCode)
            {
                var info = await response.Content.ReadFromJsonAsync<UserInfo>();
                if (info != null)
                {
                    username = info.Email;
                    isLoggedIn = true;
                }
            }
        }
        catch
        {
            // Ignore if fetch fails
        }
        isLoaded = true;
    }

    public class UserInfo
    {
        public string Email { get; set; } = string.Empty;
    }

    public class JoinResponse
    {
        public string Url { get; set; } = "";
    }

    private async Task JoinLobby()
    {
        if (!string.IsNullOrWhiteSpace(JoinCode))
        {
            var response = await Http.GetAsync($"/join/{JoinCode}");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<JoinResponse>();
                if (!string.IsNullOrEmpty(result?.Url))
                {
                    Nav.NavigateTo(result.Url);
                }
            }
        }
    }
}
