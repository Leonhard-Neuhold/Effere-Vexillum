@page "/play/{LobbyId:guid}"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<MudText Typo="Typo.h4" GutterBottom="true">Game Phase</MudText>

@if (_isDrawingPhase)
{
    @if (!_hasSubmittedDrawing)
    {
        <MudText Typo="Typo.h5">Draw the flag: @_flagToDraw!</MudText>
        <canvas id="drawingCanvas" width="400" height="300" style="cursor: crosshair; border: 1px solid black; display: block;" @onmousedown="BeginDraw" @onmousemove="Draw" @onmouseup="EndDraw"></canvas>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitDrawing" Class="mt-4">Submit Drawing</MudButton>
    }
    else
    {
        <MudText Typo="Typo.h5">Waiting for other players to finish drawing...</MudText>
    }
}
else
{
    <MudText Typo="Typo.h5">Guess the flag!</MudText>
    @if (!string.IsNullOrEmpty(_currentImageObject))
    {
        <img src="/api/drawings/@_currentImageObject" alt="Flag to guess" width="400" height="300" style="border: 1px solid black;" />
    }
    <MudTextField @bind-Value="_guess" Label="Your Guess" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitGuess" Class="mt-4">Submit Guess</MudButton>
}

@code {
    [Parameter] public Guid LobbyId { get; set; }
    private bool _isDrawingPhase = true;
    private bool _hasSubmittedDrawing = false;
    private bool _canvasInitialized = false;
    private string _guess = "";
    private string _currentImageObject = "";
    private string _flagToDraw = "";
    private Guid _gameId;
    private int _roundNumber;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadGameState();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/lobby"))
            .Build();

        _hubConnection.On<int>("RoundStarted", async (_) =>
        {
            await LoadGameState();
            _isDrawingPhase = true;
            _hasSubmittedDrawing = false;
            _canvasInitialized = false;
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<int>("DrawingPhaseFinished", async (_) =>
        {
            await LoadGameState();
            _isDrawingPhase = false;
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<int>("RoundFinished", async (_) =>
        {
            await LoadGameState();
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<Guid>("GameFinished", (gameId) =>
        {
            Nav.NavigateTo($"/results/{gameId}");
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("JoinLobbyGroup", LobbyId.ToString());
    }

    private async Task LoadGameState()
    {
        var result = await Http.GetFromJsonAsync<GameStateDto>($"/api/lobbies/{LobbyId}/game");
        if (result != null)
        {
            _gameId = result.GameId;
            _roundNumber = result.RoundNumber;
            _isDrawingPhase = result.State == "drawing";
            _flagToDraw = result.FlagToDraw ?? "";
            _currentImageObject = result.ImageToGuess ?? "";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("eval", @"
                window.setupCanvas = () => {
                    const canvas = document.getElementById('drawingCanvas');
                    if (!canvas) return;
                    const ctx = canvas.getContext('2d');
                    ctx.fillStyle = 'white';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    let isDrawing = false;
                    canvas.onmousedown = (e) => { isDrawing = true; ctx.beginPath(); ctx.moveTo(e.offsetX, e.offsetY); };
                    canvas.onmousemove = (e) => { if (isDrawing) { ctx.lineTo(e.offsetX, e.offsetY); ctx.stroke(); } };
                    canvas.onmouseup = () => { isDrawing = false; };
                    canvas.onmouseout = () => { isDrawing = false; };
                };
                window.getCanvasData = () => {
                    return document.getElementById('drawingCanvas').toDataURL('image/png');
                };
            ");
        }

        if (_isDrawingPhase && !_hasSubmittedDrawing && !_canvasInitialized)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("setupCanvas");
                _canvasInitialized = true;
            }
            catch { }
        }
    }

    private void BeginDraw() { }
    private void Draw() { }
    private void EndDraw() { }

    private async Task SubmitDrawing()
    {
        var dataUrl = await JsRuntime.InvokeAsync<string>("getCanvasData");
        var base64 = dataUrl.Split(',')[1];
        var bytes = Convert.FromBase64String(base64);
        var content = new ByteArrayContent(bytes);
        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("image/png");

        using var contentMulti = new MultipartFormDataContent();
        contentMulti.Add(new StringContent(LobbyId.ToString()), "lobbyId");
        contentMulti.Add(new StringContent(_gameId.ToString()), "gameId");
        contentMulti.Add(new StringContent(_roundNumber.ToString()), "roundNumber");
        contentMulti.Add(content, "file", "drawing.png");

        var response = await Http.PostAsync("/api/upload-drawing", contentMulti);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
            if (result != null && !string.IsNullOrEmpty(result.Path))
            {
                await Http.PostAsJsonAsync("/api/submit-drawing", new 
                { 
                    GameId = _gameId, 
                    RoundNumber = _roundNumber, 
                    ImagePath = result.Path 
                });
                _hasSubmittedDrawing = true;
            }
        }
    }

    private async Task SubmitGuess()
    {
        // Submit guess to backend...
        await Http.PostAsJsonAsync($"/api/guess", new { GameId = _gameId, RoundNumber = _roundNumber, Guess = _guess });
        _guess = "";
    }

    public class GameStateDto
    {
        public Guid GameId { get; set; }
        public int RoundNumber { get; set; }
        public string State { get; set; } = "";
        public string? FlagToDraw { get; set; }
        public string? ImageToGuess { get; set; }
    }

    public class UploadResponse 
    {
        public string? Path { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
