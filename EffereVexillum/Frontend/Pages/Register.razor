@page "/register"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IDialogService DialogService
<MudText Typo="Typo.h4" GutterBottom="true">Register</MudText>
<MudPaper Class="pa-4" MaxWidth="400px">
    <MudForm @ref="form" @bind-IsValid="@success">
        <MudTextField @bind-Value="registerModel.Email" Label="Email" Required="true" RequiredError="Email is required!" OnKeyDown="HandleKeyDown" />
        <MudTextField @bind-Value="registerModel.Password" Label="Password" InputType="InputType.Password" Required="true" RequiredError="Password is required!" OnKeyDown="HandleKeyDown" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!success)" OnClick="Submit" Class="mt-4">Register</MudButton>
    </MudForm>
</MudPaper>
@code {
    bool success;
    MudForm? form;
    RegisterModel registerModel = new();
    
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Submit();
        }
    }

    private async Task Submit()
    {
        if (form is not null)
        {
            await form.ValidateAsync();
        }
        if (form is { IsValid: true })
        {
            var response = await Http.PostAsJsonAsync("/api/auth/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                var errorMsg = await GetErrorMessage(response);
                await DialogService.ShowMessageBoxAsync("Registration Failed", errorMsg, yesText: "OK");
            }
        }
    }
    private async Task<string> GetErrorMessage(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
            if (problem?.Errors != null && problem.Errors.Any())
            {
                var errors = problem.Errors.SelectMany(kvp => kvp.Value).ToList();
                return string.Join("\n", errors);
            }
            if (!string.IsNullOrEmpty(problem?.Title))
            {
                return problem.Title;
            }
        }
        catch { }
        return "An unknown error occurred during registration.";
    }
    public class RegisterModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
    public class ProblemDetails
    {
        public string? Title { get; set; }
        public Dictionary<string, string[]>? Errors { get; set; }
    }
}
