@page "/guess-flags"
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Practice Flags</MudText>
    
    @if (!_isLoading)
    {
        <div class="mb-4">
            <MudSelect T="string" Label="Category" Value="@_selectedCategory" ValueChanged="OnCategoryChanged" Variant="Variant.Outlined">
                @foreach (var cat in _availableCategories)
                {
                    <MudSelectItem Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>
        </div>
    }

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-block mx-auto" />
    }
    else if (_finished)
    {
        <MudCard Class="pa-4 text-center">
            <MudText Typo="Typo.h4" Color="Color.Success" Class="mb-4">Completed!</MudText>
            <MudText Typo="Typo.h6">You guessed @_correctCount out of @_guessedCount correctly.</MudText>
            
            @if (_guessedCount > 0)
            {
                <div class="d-flex justify-center my-4">
                    <MudChart T="double" ChartType="ChartType.Pie" ChartSeries="@(new double[]{_correctCount, _wrongFlags.Count}.AsChartDataSet())" 
                              ChartLabels="@(new[]{$"Correct ({_correctCount})", $"Wrong ({_wrongFlags.Count})"})" 
                              Width="300px" Height="300px" />
                </div>
            }

            <div class="d-flex justify-center gap-4 mt-4">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Restart">Restart All</MudButton>
                @if (_wrongFlags.Count > 0)
                {
                    <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="PracticeWrongFlags">Practice Wrong Flags</MudButton>
                }
            </div>
        </MudCard>
    }
    else if (_picturesToGuess.Count > 0)
    {
        <MudGrid>
            <MudItem xs="12" Class="d-flex justify-space-between mb-4">
                <MudText Typo="Typo.subtitle1">Total: @_totalCount</MudText>
                <MudText Typo="Typo.subtitle1">Guessed: @_guessedCount</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Success">Correct: @_correctCount</MudText>
            </MudItem>
        </MudGrid>

        <MudCard>
            <div class="d-flex justify-center align-center" style="height: 400px; padding: 16px; background-color: #fafafa;">
                <img src="@GetImageUrl(_currentPicture)" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="Flag to guess" />
            </div>
            <MudCardContent>
                <MudTextField @ref="_mudTextField" @bind-Value="_userGuess" Label="Your Guess" Variant="Variant.Outlined" Immediate="true" OnKeyDown="OnKeyDown" ReadOnly="_showResult" />
                @if (_showResult)
                {
                    <MudText Typo="Typo.h6" Class="mt-2" Color="@(_wasCorrect ? Color.Success : Color.Error)">
                        @_resultMessage
                    </MudText>
                }
            </MudCardContent>
            <MudCardActions Class="justify-center">
                @if (!_showResult)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitGuess" Disabled="@string.IsNullOrWhiteSpace(_userGuess)">Submit</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="FinishEarly" Class="ml-2">End Practice</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="NextFlagAsync">Next</MudButton>
                }
            </MudCardActions>
        </MudCard>
    }
    else
    {
        <MudText Typo="Typo.h5" Align="Align.Center">No flags found to guess.</MudText>
    }
</MudContainer>

@code {
    private MudTextField<string>? _mudTextField;

    private List<string> _allPictures = [];
    private List<string> _picturesToGuess = [];
    private List<string> _wrongFlags = [];
    
    private int _totalCount;
    private int _guessedCount;
    private int _correctCount;
    
    private string _currentPicture = "";
    private string _userGuess = "";
    
    private bool _isLoading = true;
    private bool _finished;
    private bool _showResult;
    private bool _wasCorrect;
    private string _resultMessage = "";
    private Dictionary<string, List<string>> _flagAliases = new();
    private Dictionary<string, string> _flagCategories = new();
    
    private string _selectedCategory = "All";
    private List<string> _availableCategories = new() { "All" };

    protected override async Task OnInitializedAsync()
    {
        await LoadFlags();
    }

    private async Task LoadFlags()
    {
        _isLoading = true;
        try
        {
            var flagsRes = await Http.GetFromJsonAsync<List<FlagDto>>("/api/flags");
            if (flagsRes != null)
            {
                foreach (var f in flagsRes)
                {
                    _flagAliases[f.Name] = f.Aliases ?? new List<string>();
                    _flagCategories[f.Name] = f.Category ?? "Unknown";
                    if (!string.IsNullOrEmpty(f.Category) && !_availableCategories.Contains(f.Category))
                    {
                        _availableCategories.Add(f.Category);
                    }
                }
                _availableCategories.Sort();
                if (_availableCategories.Contains("All"))
                {
                    _availableCategories.Remove("All");
                    _availableCategories.Insert(0, "All");
                }
            }

            var res = await Http.GetFromJsonAsync<List<string>>("/api/pictures/");
            if (res != null)
            {
                _allPictures = res;
                foreach (var pic in _allPictures)
                {
                    Console.WriteLine(pic);
                }
            }
            Restart();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Restart()
    {
        _picturesToGuess = new List<string>();
        foreach (var p in _allPictures)
        {
            var expected = GetExpectedAnswer(p);
            var cat = _flagCategories.TryGetValue(expected, out var c) ? c : "Unknown";
            
            if (_selectedCategory == "All" || cat == _selectedCategory)
            {
                _picturesToGuess.Add(p);
            }
        }
        _wrongFlags.Clear();
        Shuffle(_picturesToGuess);
        _totalCount = _picturesToGuess.Count;
        _guessedCount = 0;
        _correctCount = 0;
        _finished = false;
        _ = PrepareNextAsync();
    }

    private void PracticeWrongFlags()
    {
        _picturesToGuess = new List<string>(_wrongFlags);
        _wrongFlags.Clear();
        Shuffle(_picturesToGuess);
        _totalCount = _picturesToGuess.Count;
        _guessedCount = 0;
        _correctCount = 0;
        _finished = false;
        _ = PrepareNextAsync();
    }

    private async Task PrepareNextAsync()
    {
        if (_picturesToGuess.Count == 0)
        {
            _finished = true;
            StateHasChanged();
            return;
        }
        _currentPicture = _picturesToGuess[0];
        _userGuess = "";
        _showResult = false;
        
        StateHasChanged();
        await Task.Delay(50);
        if (_mudTextField != null)
        {
            await _mudTextField.FocusAsync();
        }
    }

    private string GetImageUrl(string pictureInfo)
    {
        return $"{Http.BaseAddress}api/pictures/{pictureInfo}";
    }

    private static string GetExpectedAnswer(string path)
    {
        var name = Path.GetFileNameWithoutExtension(path);
        return name.Replace("_", " ").Trim();
    }

    private int ComputeLevenshteinDistance(string source, string target)
    {
        if (string.IsNullOrEmpty(source)) return target?.Length ?? 0;
        if (string.IsNullOrEmpty(target)) return source.Length;

        var sourceLower = source.ToLowerInvariant().Replace(" ", "").Replace("-", "");
        var targetLower = target.ToLowerInvariant().Replace(" ", "").Replace("-", "");

        int sourceLength = sourceLower.Length;
        int targetLength = targetLower.Length;

        int[,] distance = new int[sourceLength + 1, targetLength + 1];

        for (int i = 0; i <= sourceLength; distance[i, 0] = i++) { }
        for (int j = 0; j <= targetLength; distance[0, j] = j++) { }

        for (int i = 1; i <= sourceLength; i++)
        {
            for (int j = 1; j <= targetLength; j++)
            {
                int cost = (targetLower[j - 1] == sourceLower[i - 1]) ? 0 : 1;
                distance[i, j] = Math.Min(
                                    Math.Min(distance[i - 1, j] + 1, distance[i, j - 1] + 1),
                                    distance[i - 1, j - 1] + cost);
            }
        }

        return distance[sourceLength, targetLength];
    }

    private bool IsGuessAcceptable(string guess, string expected)
    {
        if (string.IsNullOrWhiteSpace(guess)) return false;

        var validAnswers = new List<string> { expected };
        if (_flagAliases.TryGetValue(expected, out var aliases))
        {
            validAnswers.AddRange(aliases);
        }

        foreach (var answer in validAnswers)
        {
            if (string.IsNullOrWhiteSpace(answer)) continue;

            var normalizedGuess = guess.ToLowerInvariant().Replace(" ", "").Replace("-", "");
            var normalizedAnswer = answer.ToLowerInvariant().Replace(" ", "").Replace("-", "");

            if (normalizedGuess == normalizedAnswer)
                return true;

            var distance = ComputeLevenshteinDistance(normalizedGuess, normalizedAnswer);
            var maxDistance = Math.Max(1, normalizedAnswer.Length / 4);

            if (distance <= maxDistance)
                return true;
        }

        return false;
    }

    private void SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(_userGuess)) return;

        var expected = GetExpectedAnswer(_currentPicture);
        _wasCorrect = IsGuessAcceptable(_userGuess.Trim(), expected);

        if (_wasCorrect)
        {
            _correctCount++;
            _resultMessage = "Correct!";
        }
        else
        {
            _wrongFlags.Add(_currentPicture);
            _resultMessage = $"Wrong! The correct answer was {expected}.";
        }

        _guessedCount++;
        _showResult = true;
    }

    private async Task NextFlagAsync()
    {
        _picturesToGuess.RemoveAt(0);
        await PrepareNextAsync();
    }

    private void FinishEarly()
    {
        _picturesToGuess.Clear();
        _finished = true;
        StateHasChanged();
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        if (!_showResult)
            SubmitGuess();
        else
            _ = NextFlagAsync();
    }

    private void OnCategoryChanged(string? newCategory)
    {
        _selectedCategory = newCategory ?? "All";
        Restart();
    }

    private static void Shuffle<T>(List<T> list)
    {
        var rng = new Random();
        var n = list.Count;
        while (n > 1)
        {
            n--;
            var k = rng.Next(n + 1);
            (list[k], list[n]) = (list[n], list[k]);
        }
    }

    private class FlagDto
    {
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public List<string> Aliases { get; set; } = new();
    }
}

