@page "/register"
@inject HttpClient Http
@inject NavigationManager Nav

<MudText Typo="Typo.h4" GutterBottom="true">Register</MudText>

<MudPaper Class="pa-4" MaxWidth="400px">
    <MudForm @ref="form" @bind-IsValid="@success">
        <MudTextField @bind-Value="registerModel.Email" Label="Email" Required="true" RequiredError="Email is required!" />
        <MudTextField @bind-Value="registerModel.Password" Label="Password" InputType="InputType.Password" Required="true" RequiredError="Password is required!" />
        
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!success)" OnClick="Submit" Class="mt-4">Register</MudButton>
    </MudForm>
</MudPaper>

@code {
    bool success;
    MudForm? form;
    RegisterModel registerModel = new();

    private async Task Submit()
    {
        if (form is not null)
        {
            await form.ValidateAsync();
        }
        if (form is { IsValid: true })
        {
            var response = await Http.PostAsJsonAsync("/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/login");
            }
        }
    }

    public class RegisterModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

